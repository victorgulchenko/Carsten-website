# Kopiere diese Datei nach .env.local und trage deine Werte ein.

# Groq API-Key — https://console.groq.com/keys
# Ohne Key läuft die Seite im Degraded-Modus (echte RSS-Schlagzeilen, ruhige Carsten-Spalte).
GROQ_API_KEY=

# Groq-Modell für die Kuratierung. Standard passt ins kostenlose 30k-TPM-Tier.
# groq/compound (mit Websuche) ist agentisch und sprengt das Free-Tier — nur mit bezahltem Tier.
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: schützt den Refresh-Endpunkt. Auf Vercel als Env-Var setzen — der Cron
# sendet ihn automatisch als "Authorization: Bearer <CRON_SECRET>".
CRON_SECRET=
