# Kopiere diese Datei nach .env.local und trage deine Werte ein.

# OpenRouter API-Key — https://openrouter.ai/keys
# Powert BEIDES: die tägliche KI-News-Kuratierung (+ "Für Carsten") und die
# Chat-Seite "Carsten GPT". Ohne Key läuft die News-Seite im Degraded-Modus
# (echte RSS-Schlagzeilen, ruhige Carsten-Spalte) und der Chat zeigt einen Hinweis.
OPENROUTER_API_KEY=

# Modell für News-Kuratierung und Carsten GPT.
OPENROUTER_MODEL=deepseek/deepseek-v4-pro

# Optional: schützt den Refresh-Endpunkt. Auf Vercel als Env-Var setzen — der Cron
# sendet ihn automatisch als "Authorization: Bearer <CRON_SECRET>".
CRON_SECRET=
